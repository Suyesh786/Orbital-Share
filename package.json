{
  "name": "airspace",
  "private": true,
  "version": "1.0.0",
  "description": "AirSpace — Secure Local File Sharing Platform",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "dist:mac": "npm run build && electron-builder",
    "dev:server": "node server/server.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "electron-builder --mac",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-websocket": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dnssd": "^0.4.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "pngjs": "^7.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "plist": "^3.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.airspace.desktop",
    "productName": "AirSpace",
    "executableName": "AirSpace",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "build/icon.icns",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "src/assets/logo/airspace-tray-icon-template.png",
        "to": "assets/logo/airspace-tray-icon-template.png"
      },
      {
        "from": "src/assets/logo/airspace-tray-icon-off-template.png",
        "to": "assets/logo/airspace-tray-icon-off-template.png"
      },
      {
        "from": "src/assets/logo/airspace-tray-icon-visible.png",
        "to": "assets/logo/airspace-tray-icon-visible.png"
      },
      {
        "from": "src/assets/logo/airspace-tray-icon-off-visible.png",
        "to": "assets/logo/airspace-tray-icon-off-visible.png"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "extendInfo": {
        "CFBundleDisplayName": "AirSpace",
        "CFBundleName": "AirSpace",
        "NSLocalNetworkUsageDescription": "AirSpace requires local network access to discover nearby devices for file sharing.",
        "NSBonjourServices": [
          "_airspace._tcp"
        ]
      }
    },
    "dmg": {
      "icon": "build/icon.icns"
    }
  }
}
